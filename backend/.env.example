# ==============================================================================
# WELFAREINTEL BACKEND ENVIRONMENT TEMPLATE (.env.example)
# Copy this file to .env before running locally or deploying to Render / Vercel
# ==============================================================================

DATABASE_URL='postgresql://your-database-user:password@your-db-host.neon.tech/neondb?sslmode=require'

# OAuth Configurations (Google SSO)
GOOGLE_CLIENT_ID='your-google-client-id.apps.googleusercontent.com'
GOOGLE_CLIENT_SECRET='your-google-client-secret'
FRONTEND_URL=http://localhost:8081
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ==============================================================================
# OPTION 2 (Recommended & Free): Groq Vision API (100% FREE Tier)
# ==============================================================================
# 1. Sign up free at: https://console.groq.com/keys
# 2. Paste your API key below:
GROQ_API_KEY='gsk_YourFreeGroqApiKeyHere'
VLM_MODEL='llama-3.2-11b-vision-preview'

# ==============================================================================
# OPTION 1 (Alternative Free Tier): Google Gemini API (100% FREE Tier)
# ==============================================================================
# 1. Get a free API key at: https://aistudio.google.com/app/apikey
# 2. Paste your API key below:
GEMINI_API_KEY='AIzaSyYourFreeGeminiApiKeyHere'
GEMINI_MODEL='gemini-2.0-flash'

# ==============================================================================
# OPTION 4 (Automatic Offline Fallback): Built-in Layout & OCR Engine
# ==============================================================================
# If both GROQ_API_KEY and GEMINI_API_KEY are left commented/blank when deployed,
# Option 4 automatically kicks in: using PyMuPDF and deterministic rules to extract
# data from PDFs and images locally with ZERO external API calls or GPU needs.
